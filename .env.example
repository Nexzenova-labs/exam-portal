# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (get from your Supabase project dashboard)
DATABASE_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# ─── Email / SMTP ──────────────────────────────────────────────────────────────
# Use Gmail App Password, Hostinger, or any SMTP provider
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Exam Portal <your-email@example.com>"

# ─── Twilio SMS (optional) ─────────────────────────────────────────────────────
# Leave blank to skip SMS verification entirely
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ─── App URL ───────────────────────────────────────────────────────────────────
# Change to your deployed domain in production
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Admin Credentials ─────────────────────────────────────────────────────────
# Used to seed the first admin account on first run
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="ChangeMe@123"

# ─── JWT Secret ────────────────────────────────────────────────────────────────
# Generate a strong random string: openssl rand -hex 32
JWT_SECRET="replace-with-a-long-random-secret"
